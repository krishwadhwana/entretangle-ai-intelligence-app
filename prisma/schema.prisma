generator client {
  provider = "prisma-client-js"
  // "native" covers local dev; the linux targets cover Railway/containers.
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  // Pooled (PgBouncer) endpoint for the app's runtime queries.
  url       = env("DATABASE_URL")
  // Direct (non-pooled) endpoint — Prisma uses this for migrations / db push,
  // which need a real session and can't run through the transaction pooler.
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts       Account[]
  sessions       Session[]
  projects       Project[]
  runs           Run[]
  workspaceNodes WorkspaceNode[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// The durable workspace: one project = one venture. Everything the UI can
// show is recoverable from this row (plus the Run machinery it points to).
model Project {
  id                  String   @id @default(cuid())
  ownerId             String?  @map("owner_id")
  name                String
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  // JSONB: { messages: ChatMessage[], pending: {question,options,multiSelect} | null, done: boolean, brief?: string }
  interviewTranscript Json     @default("{\"messages\":[],\"pending\":null,\"done\":false}") @map("interview_transcript")
  // JSONB: ClientProfile incl. product, category, priceBand, geography, targetAudience, funding
  ventureProfile      Json?    @map("venture_profile")
  // JSONB: { desks, cohortPlan } from the planner — the audience matrix
  audienceConfig      Json?    @map("audience_config")
  // JSONB: append-only array of { runId, timestamp, params, results }
  simulationRuns      Json     @default("[]") @map("simulation_runs")
  // JSONB: Owner Dashboard state — extensible container of owner-facing tools.
  // Today: { brandSocial: { kit, checks, generatedAt, sourceRunId } }
  ownerDashboard      Json?    @map("owner_dashboard")
  // JSONB: result of analysing the founder's website + online consumer opinion
  // at project creation — { url, draftProfile, knownFields, consumerOpinion,
  // sentiment, summary, sources, analyzedAt }. Pre-fills the intake + seeds the
  // simulation with real consumer sentiment.
  websiteAnalysis     Json?    @map("website_analysis")
  // JSONB: web-sourced market benchmark overrides, keyed "<market>:<category>"
  // (e.g. "US:apparel") → { ranges + sources + asOf }. Refines the curated
  // benchmark priors with current, cited figures for the venture's market.
  marketData          Json?    @map("market_data")

  owner     User?      @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  runs      Run[]
  documents Document[]
  jobs      RunJob[]
  simulationRunRows ProjectSimulationRun[]

  @@index([ownerId, updatedAt])
  @@map("projects")
}

// One completed simulation snapshot, extracted out of Project.simulationRuns
// (the append-only JSONB array). That array grew unbounded and Postgres
// rewrites the whole project row on every append (TOAST churn, slow reads).
// Here each run is its own row, so appending a run no longer rewrites the
// others, and reads can paginate. `record` holds the full SimulationRunRecord
// (lib/schema.ts) verbatim so the storage swap needs no shape change upstream.
// Dual-written alongside the legacy JSONB array during rollout; the array is
// the read source of truth until the read path is cut over and contracted.
model ProjectSimulationRun {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  runId     String   @unique @map("run_id")
  timestamp DateTime
  record    Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, timestamp])
  @@map("project_simulation_runs")
}

// Nested organizer shared by the dashboard and project workspaces. One table
// backs folders, saved dashboard views, project placements, and saved PDF
// export records.
model WorkspaceNode {
  id           String   @id @default(cuid())
  ownerId      String?  @map("owner_id")
  scope        String
  projectId    String?  @map("project_id")
  parentId     String?  @map("parent_id")
  kind         String
  title        String
  note         String   @default("")
  refProjectId String?  @map("ref_project_id")
  moduleId     String?  @map("module_id")
  payload      Json     @default("{}")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  owner User? @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([ownerId, scope, projectId])
  @@index([scope, projectId])
  @@index([parentId])
  @@index([refProjectId])
  @@map("workspace_nodes")
}

// Founder-uploaded reference data (sales, surveys, competitor lists, …) used
// as RAG ground truth: research desks and audience synthesis retrieve the
// most relevant chunks of these and treat them as fact (SPEC-V2 §1A "pull
// from real data"). Chunks + their embedding vectors live in one JSONB column
// so retrieval is a single-row read + in-process cosine (no pgvector needed).
model Document {
  id         String   @id @default(cuid())
  projectId  String   @map("project_id")
  name       String
  charCount  Int      @map("char_count")
  chunkCount Int      @map("chunk_count")
  embModel   String   @map("emb_model") // which embedder produced the vectors
  // JSONB: [{ idx, content, embedding: number[] }]
  chunks     Json
  createdAt  DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("documents")
}

model Run {
  id               String   @id @default(cuid())
  ownerId          String?  @map("owner_id")
  projectId        String?
  brief            String
  clientProfile    String // Json (ClientProfile)
  status           String // RunStatus
  parentRunId      String?
  forkPointBlockId String?
  // Follow-up simulations: a focus question + extra context steer the run,
  // mode picks full vs. scoped, sourceRunId is the run a scoped run reuses
  // the simulated audience from.
  focusQuestion     String?
  additionalContext String?
  mode              String  @default("full") // "full" | "scoped" | "export"
  sourceRunId       String?
  // Cross-border export run: a dependent run that tests the venture in a new
  // market. parentRunId points at the completed home-market (e.g. India) run
  // whose proven results are carried forward as priors; targetMarket is the
  // destination country (e.g. "United States"). mode === "export".
  targetMarket      String?
  // Per-run audience size chosen in the UI (slider/number). Null → use the
  // TARGET_AUDIENCE_SIZE env default. 0 → research desks only, no audience.
  targetAudienceSize Int?
  tokensUsed       Int      @default(0)
  costUsd          Float    @default(0)
  createdAt        DateTime @default(now())

  owner   User?      @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  project Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  blocks  Block[]
  edges   Edge[]
  events  RunEvent[]
  cohorts Cohort[]
  jobs    RunJob[]
  launchSims LaunchSimulation[]
  launchOutcomes LaunchOutcome[]

  @@index([ownerId])
  @@index([projectId])
}

// Durable execution queue for expensive run work. API routes enqueue jobs;
// a separate worker process claims them and executes the engine, so Next.js
// navigation/dev-server restarts do not own long-running simulations.
model RunJob {
  id              String    @id @default(cuid())
  runId           String?   @map("run_id")
  projectId       String?   @map("project_id")
  type            String // "execute" | "resume" | project-level owner jobs
  status          String    @default("queued") // queued|running|succeeded|failed|cancelled
  priority        Int       @default(0)
  attempts        Int       @default(0)
  maxAttempts     Int       @default(1) @map("max_attempts")
  lockedBy        String?   @map("locked_by")
  lockedAt        DateTime? @map("locked_at")
  startedAt       DateTime? @map("started_at")
  finishedAt      DateTime? @map("finished_at")
  cancelRequested Boolean   @default(false) @map("cancel_requested")
  error           String?
  payload         Json?
  result          Json?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  run     Run?     @relation(fields: [runId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([status, priority, createdAt])
  @@index([runId, status])
  @@index([projectId, status])
  @@map("run_jobs")
}

model Block {
  id            String @id @default(cuid())
  runId         String
  name          String
  mission       String
  layer         Int
  kind          String @default("research") // "research" | "synthesis" | "audience"
  domain        String @default("market") // market|competitor|channel|regulation|pricing|social|audience|synthesis
  state         String // BlockState
  inputBlockIds String // Json string[]
  params        String // Json Record<string, number | string>
  logs          String // Json string[]

  run         Run          @relation(fields: [runId], references: [id])
  conclusions Conclusion[]

  @@index([runId])
}

model Conclusion {
  id         String @id @default(cuid())
  blockId    String
  claim      String
  value      String
  confidence Float
  entities   String // Json string[]
  sources    String // Json string[]

  block Block @relation(fields: [blockId], references: [id])

  @@index([blockId])
}

model Edge {
  id          String @id @default(cuid())
  runId       String
  fromBlockId String
  toBlockId   String
  kind        String // "entangle" | "feeds"
  reason      String

  run Run @relation(fields: [runId], references: [id])

  @@index([runId])
}

// One simulated audience cohort = locality x income segment x role.
// A single mini-model call simulates `size` personas for the cohort.
model Cohort {
  id        String  @id @default(cuid())
  runId     String
  label     String // e.g. "Mumbai · affluent · consumer"
  locality  String // city/neighbourhood name
  country   String
  lat       Float
  lng       Float
  segment   String // "budget" | "middle" | "affluent" | "luxury"
  role      String // "consumer" | "retail_exec" | "institutional" | "distributor" | "influencer"
  weightPct Float // share of the addressable audience this cohort represents
  size      Int // personas simulated in this cohort
  state     String  @default("pending") // "pending" | "simulating" | "done" | "failed"
  stats     String? // Json CohortStats
  summary   String?

  run      Run       @relation(fields: [runId], references: [id])
  personas Persona[]

  @@index([runId])
}

model Persona {
  id          String @id @default(cuid())
  cohortId    String
  name        String
  age         Int
  gender      String
  occupation  String
  incomeBand  String
  lat         Float
  lng         Float
  intent      Float // 0–1 purchase/stocking intent
  wtp         Float // willingness to pay (in wtpCurrency)
  wtpCurrency String
  channelPref String
  platforms   String // Json string[] social platforms
  objection   String
  quote       String

  // Depth fields — the "why" behind intent/WTP, not just the numbers.
  lifestyle        String @default("") // daily routine, work hours, social habits
  lifeStage        String @default("") // household / living / family context
  values           String @default("[]") // Json string[] — decision drivers
  shoppingHabits   String @default("") // how/where/how often they shop this category
  priceSensitivity Float  @default(0.5) // 0–1, 1 = extremely price-sensitive
  reasoning        String @default("") // explicit life -> intent & price-tier chain
  personality       String @default("") // distinct temperament, flavoured by locality
  personalityTraits String @default("[]") // Json string[] — personality trait tags

  // Win-back: a 1:1 chat can move a non-approver's vote. We keep the original
  // pre-chat intent so the UI can show "was X% -> Y%", plus a transcript.
  intentOriginal Float?    // pre-chat intent, set on the first vote change
  voteChangedAt  DateTime? // when intent was last changed via win-back chat
  chatLog        String   @default("[]") // Json — win-back conversation transcript

  cohort Cohort @relation(fields: [cohortId], references: [id])

  @@index([cohortId])
}

// A "Persona Interaction": 2-4 simulated personas discuss a topic turn-by-turn.
// Replies are generated one at a time (the user clicks "reply from X") to keep
// cost bounded; the founder can inject knowledge mid-conversation (a "founder"
// message every persona then sees), and the discussion can be wrapped up into a
// synthesized conclusion. Persisted so it survives drawer close / reload.
model PersonaConversation {
  id         String   @id @default(cuid())
  runId      String   @map("run_id")
  // Json string[] of the 2-4 participant persona ids (source of truth).
  participantIds String @default("[]") @map("participant_ids")
  // Legacy first-two participants, kept populated for back-compat reads.
  personaAId String   @map("persona_a_id")
  personaBId String   @map("persona_b_id")
  topic      String   @default("")
  // Json: [{ speaker, personaId|null, role: "persona"|"founder",
  //          content, intentAfter|null, ts }]
  messages   String   @default("[]")
  conclusion String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([runId])
  @@map("persona_conversations")
}

// A saved Launch Simulation scenario. The engine is deterministic over the
// run's frozen personas, so the inputs alone reproduce the result — but we
// persist the computed result too so saved scenarios render instantly and can
// be compared side by side without recomputation. projectId mirrors Run so a
// scenario survives even if its run row is later detached.
model LaunchSimulation {
  id        String   @id @default(cuid())
  runId     String   @map("run_id")
  projectId String?  @map("project_id")
  name      String   @default("Scenario")
  inputs    Json // LaunchSimInputs
  result    Json // LaunchSimResult
  // JSONB: "Ask about this scenario" follow-up Q&A — [{question,answer,ts}]
  followUp  Json     @default("[]") @map("follow_up")
  createdAt DateTime @default(now()) @map("created_at")

  run Run @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, createdAt])
  @@map("launch_simulations")
}

// First-party capture (the moat): a REAL launch outcome recorded against a run.
// Stores the inputs that were used, a frozen audience snapshot at capture time,
// and the actual observed metrics — so the backtest harness (lib/backtest.ts)
// can replay it through the sim and score predicted-vs-actual. This is the data
// that turns the harness from a demo (synthetic fixtures) into real validation.
model LaunchOutcome {
  id           String   @id @default(cuid())
  runId        String   @map("run_id")
  projectId    String?  @map("project_id")
  label        String   @default("Outcome")
  source       String   @default("founder-reported") // founder-reported | shopify-export | ...
  horizonLabel String?  @map("horizon_label") // e.g. "first 90 days"
  notes        String?
  inputs       Json // LaunchSimInputs that were used (replayed by the harness)
  audience     Json // frozen LaunchPersona[] snapshot at capture time
  actual       Json // ActualOutcome — observed metrics over the horizon
  createdAt    DateTime @default(now()) @map("created_at")

  run Run @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, createdAt])
  @@map("launch_outcomes")
}

model RunEvent {
  id      String @id @default(cuid())
  runId   String
  seq     Int
  type    String
  payload String // Json
  ts      BigInt

  run Run @relation(fields: [runId], references: [id])

  @@unique([runId, seq])
  @@index([runId, seq])
}

// Auto-built, globally-shared industry knowledge (option A). One agent
// researches an industry once and caches a knowledge pack + planning template
// here, with provenance + freshness; all runs in that industry reuse it until
// it goes stale. Not per-project — knowledge is shared across the platform.
model IndustryKnowledge {
  id          String   @id @default(cuid())
  industryKey String   @unique @map("industry_key") // normalized libraryKey/slug
  industry    String
  pack        Json // IndustryKnowledgePack (summary, facts[], planningTemplate)
  sources     Json     @default("[]") // string[]
  builtModel  String   @default("") @map("built_model")
  builtAt     DateTime @default(now()) @map("built_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("industry_knowledge")
}

// Globally shared company intelligence: company identity, exchange listings,
// filings, sourced profile snapshots, financial facts, price snapshots and
// daily news. Tables are global rather than per-project so every venture/run
// can reuse the same intelligence base.
model Company {
  id              String   @id @default(cuid())
  canonicalName   String   @map("canonical_name")
  legalName       String?  @map("legal_name")
  country         String?
  website         String?
  investorWebsite String?  @map("investor_website")
  cik             String?  @unique
  lei             String?
  crunchbaseUuid      String?  @unique @map("crunchbase_uuid")
  crunchbasePermalink String?  @unique @map("crunchbase_permalink")
  sic             String?
  sicDescription  String?  @map("sic_description")
  sector          String?
  description     String   @default("")
  story           Json?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  listings      ExchangeListing[]
  profiles      CompanyProfileSnapshot[]
  filings       CorporateFiling[]
  metrics       FinancialMetric[]
  news          NewsItem[]
  sourceRecords SourceRecord[]
  founderRoles  FounderCompanyRole[]
  founderStories FounderStorySnapshot[]

  @@index([canonicalName])
  @@index([country])
  @@map("companies")
}

model Founder {
  id                  String   @id @default(cuid())
  fullName            String   @map("full_name")
  crunchbaseUuid      String?  @unique @map("crunchbase_uuid")
  crunchbasePermalink String?  @unique @map("crunchbase_permalink")
  linkedin            String?
  website             String?
  bio                 String   @default("")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  roles   FounderCompanyRole[]
  stories FounderStorySnapshot[]

  @@index([fullName])
  @@map("founders")
}

model FounderCompanyRole {
  id        String    @id @default(cuid())
  founderId String    @map("founder_id")
  companyId String    @map("company_id")
  role      String    @default("founder")
  source    String
  startedOn DateTime? @map("started_on")
  endedOn   DateTime? @map("ended_on")
  raw       Json?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  founder Founder @relation(fields: [founderId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([founderId, companyId, role, source])
  @@index([companyId])
  @@map("founder_company_roles")
}

model FounderStorySnapshot {
  id          String   @id @default(cuid())
  founderId   String?  @map("founder_id")
  companyId   String?  @map("company_id")
  source      String
  sourceType  String   @map("source_type") // licensed_api | official_page | interview | manual_upload
  url         String?
  title       String
  narrative   String   @default("")
  raw         Json?
  sources     Json     @default("[]")
  fingerprint String   @unique
  asOf        DateTime @default(now()) @map("as_of")
  createdAt   DateTime @default(now()) @map("created_at")

  founder Founder? @relation(fields: [founderId], references: [id], onDelete: SetNull)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([founderId, companyId])
  @@map("founder_story_snapshots")
}

model ExchangeListing {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  exchange    String
  mic         String?
  ticker      String
  currency    String?
  isin        String?
  active      Boolean  @default(true)
  firstSeenAt DateTime @default(now()) @map("first_seen_at")
  lastSeenAt  DateTime @default(now()) @map("last_seen_at")

  company        Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  filings        CorporateFiling[]
  priceSnapshots PriceSnapshot[]

  @@unique([exchange, ticker])
  @@index([companyId])
  @@map("exchange_listings")
}

model CompanyProfileSnapshot {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  source      String // sec-submissions | crunchbase | ...
  fingerprint String   @unique
  asOf        DateTime @default(now()) @map("as_of")
  title       String?
  summary     String   @default("")
  raw         Json
  sources     Json     @default("[]")
  createdAt   DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, source, asOf])
  @@map("company_profile_snapshots")
}

model CorporateFiling {
  id              String    @id @default(cuid())
  companyId       String    @map("company_id")
  listingId       String?   @map("listing_id")
  regulator       String // SEC | ...
  formType        String    @map("form_type")
  accessionNo     String?   @map("accession_no")
  filingDate      DateTime  @map("filing_date")
  reportDate      DateTime? @map("report_date")
  title           String
  url             String
  primaryDocument String?   @map("primary_document")
  raw             Json?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  company Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  listing ExchangeListing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  @@unique([regulator, accessionNo])
  @@index([companyId, filingDate])
  @@index([listingId])
  @@map("corporate_filings")
}

model FinancialMetric {
  id           String    @id @default(cuid())
  companyId    String    @map("company_id")
  source       String // sec-companyfacts | ...
  taxonomy     String
  metric       String
  label        String
  unit         String
  value        Float
  fiscalYear   Int?      @map("fiscal_year")
  fiscalPeriod String?   @map("fiscal_period")
  form         String?
  filedDate    DateTime? @map("filed_date")
  endDate      DateTime? @map("end_date")
  accessionNo  String?   @map("accession_no")
  frame        String?
  fingerprint  String    @unique
  raw          Json?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, metric, endDate])
  @@map("financial_metrics")
}

model PriceSnapshot {
  id         String   @id @default(cuid())
  listingId  String   @map("listing_id")
  source     String
  observedAt DateTime @map("observed_at")
  currency   String?
  open       Float?
  high       Float?
  low        Float?
  close      Float?
  volume     Float?
  raw        Json?
  createdAt  DateTime @default(now()) @map("created_at")

  listing ExchangeListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, source, observedAt])
  @@index([listingId, observedAt])
  @@map("price_snapshots")
}

model NewsItem {
  id          String    @id @default(cuid())
  companyId   String?   @map("company_id")
  source      String
  url         String    @unique
  title       String
  publishedAt DateTime? @map("published_at")
  summary     String    @default("")
  eventType   String?   @map("event_type")
  sentiment   String?
  impactScore Float?    @map("impact_score")
  raw         Json?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([companyId, publishedAt])
  @@map("news_items")
}

model SourceRecord {
  id          String   @id @default(cuid())
  companyId   String?  @map("company_id")
  source      String
  sourceType  String   @map("source_type") // official_api | licensed_api | public_authorized | manual_upload
  url         String
  retrievedAt DateTime @default(now()) @map("retrieved_at")
  fingerprint String   @unique
  rawMeta     Json?    @map("raw_meta")

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([companyId, source])
  @@map("source_records")
}
