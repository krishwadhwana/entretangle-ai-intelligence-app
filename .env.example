OPENAI_API_KEY=
MODEL_FRONTIER=gpt-5.5    # planner, desks (web search), entangler, synthesis, query
MODEL_MINI=gpt-5-mini     # batched cohort/persona simulation
MOCK_MODE=true            # true = no API calls, scripted run (SPEC-V2 §6)

# Login and verification
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-long-random-string
EMAIL_SERVER=smtp://user:password@smtp.example.com:587
EMAIL_FROM="EntreTangle <no-reply@example.com>"
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Caps (SPEC-V2 §2)
MAX_COST_USD=5
MAX_BLOCKS_PER_RUN=20
MAX_DESKS_PER_RUN=14
MAX_LAYERS=4
MAX_TOKENS_PER_RUN=600000
BLOCK_TIMEOUT_MS=180000

# Audience simulation — ~TARGET_AUDIENCE_SIZE personas spread across cohorts,
# each cohort simulated in batches of PERSONAS_PER_CALL (hard-capped at 60).
# A ~6000-persona run is roughly TARGET_AUDIENCE_SIZE/PERSONAS_PER_CALL ≈ 120
# mini-model calls; watch MAX_COST_USD if you raise the target much higher.
MAX_COHORTS=120
TARGET_AUDIENCE_SIZE=6000
PERSONAS_PER_CALL=50
MIN_PERSONAS_PER_COHORT=40
PERSONAS_PER_COHORT=40
AUDIENCE_CONCURRENCY=10
DESK_CONCURRENCY=6

# $ per 1M tokens — override as published prices move
PRICE_FRONTIER_IN=1.25
PRICE_FRONTIER_OUT=10
PRICE_MINI_IN=0.25
PRICE_MINI_OUT=2
PRICE_WEB_SEARCH=0.01

# Postgres connection string (e.g. the Railway one:
# postgresql://postgres:<password>@<host>.railway.app:5432/railway)
DATABASE_URL="postgresql://user:password@localhost:5432/entretangle"
# Direct (non-pooled) Postgres URL — used by Prisma for migrations / db push.
# On Neon, this is the non-pooled host (no "-pooler"). DATABASE_URL should be
# the pooled host; you can raise its limit, e.g. ?connection_limit=10&pool_timeout=15
DIRECT_URL="postgresql://user:password@localhost:5432/entretangle"

# Live-event transport for the run dashboard (SSE).
#   memory   (default) — in-process pub/sub; correct for a SINGLE app instance.
#   postgres           — adds cross-instance wakeups via LISTEN/NOTIFY so a
#                        dashboard on instance A sees events from a worker on
#                        instance B. Requires the `pg` package (npm i pg) and a
#                        session-mode connection: the listener uses DIRECT_URL
#                        because PgBouncer transaction pooling can't hold LISTEN.
EVENT_BUS=memory

# Logging. LOG_LEVEL: debug|info|warn|error (default: info in prod, debug in dev).
# LOG_FORMAT: json|pretty (default: json in prod, pretty in dev).
# LOG_LEVEL=info
# LOG_FORMAT=json

# Object storage for uploaded/generated images (product images, design assets).
# S3-compatible — works with Cloudflare R2, AWS S3, Backblaze B2, Supabase.
# When UNSET, images fall back to the local filesystem under data/uploads/
# (fine for dev; NOT durable on serverless — set these in production).
# Cloudflare R2 example:
#   S3_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
#   S3_REGION="auto"
S3_BUCKET=
S3_ENDPOINT=
S3_REGION="auto"
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# S3_FORCE_PATH_STYLE="true"   # set only if your provider requires path-style URLs

# Official company-intelligence connectors
# SEC asks automated clients to send an app/contact user agent.
SEC_USER_AGENT="entretangle-ai-intelligence your-email@example.com"

# Optional paid/licensed company-intelligence feeds.
NASDAQ_DATA_LINK_API_KEY=
NSE_DATA_API_KEY=
CRUNCHBASE_API_KEY=

# --- Business integrations (connected accounts) ---------------------------
# Connect a founder's real sales/ads/payments/accounting data so the
# simulation can be reconciled against actuals ("Plan vs Actual"). Each
# connector runs in seeded MOCK mode until its credentials are set here (and is
# always mocked when MOCK_MODE=true), so the whole feature is demoable with no
# credentials.
#
# AES-256-GCM key encrypting integration tokens at rest. Generate with
# `openssl rand -hex 32`. REQUIRED in production; unset = plaintext + a warning.
INTEGRATIONS_ENC_KEY=
# Base URL providers redirect back to after OAuth. Must match the redirect URI
# registered in each provider's developer app. Defaults to NEXTAUTH_URL.
# The per-provider callback path is /api/integrations/callback/<provider>.
INTEGRATIONS_REDIRECT_BASE=
# Shopify — public OAuth "install" app (self-serve): the merchant types their
# shop domain and approves on Shopify's own screen. Create the app in the
# Shopify Partner dashboard; these are the app's API key + secret (one-time,
# platform-wide — NOT per merchant).
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
# Meta (Facebook/Instagram) Ads — Marketing API. Reuses FACEBOOK_CLIENT_* if set.
META_APP_ID=
META_APP_SECRET=
# Google — GA4 + Google Ads. Use a DEDICATED OAuth client for integrations,
# separate from the login (auth) client. If these are unset, it falls back to
# the auth GOOGLE_CLIENT_* above. Set the same values on Vercel AND Railway
# (the worker refreshes Google's hourly tokens). Add the integration redirect
# URIs to this client: /api/integrations/callback/ga4 (and /google_ads).
GOOGLE_INTEGRATIONS_CLIENT_ID=
GOOGLE_INTEGRATIONS_CLIENT_SECRET=
# Google Ads also needs an approved developer token.
GOOGLE_ADS_DEVELOPER_TOKEN=
# Stripe Connect OAuth. STRIPE_CLIENT_ID is the ca_… Connect OAuth client id
# (Settings → Connect → Onboarding options → OAuth); STRIPE_SECRET_KEY (sk_…)
# authenticates the token exchange. Customers click Connect and approve on
# Stripe's own screen.
STRIPE_CLIENT_ID=
STRIPE_SECRET_KEY=
# QuickBooks Online (Intuit OAuth2).
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
# TikTok Shop (commerce) — TikTok Shop Partner app.
TIKTOK_SHOP_APP_KEY=
TIKTOK_SHOP_APP_SECRET=
# TikTok Ads (marketing) — TikTok for Business / Marketing API app.
TIKTOK_ADS_APP_ID=
TIKTOK_ADS_APP_SECRET=
# Amazon Selling Partner API — Login with Amazon (LWA) app credentials.
AMAZON_LWA_CLIENT_ID=
AMAZON_LWA_CLIENT_SECRET=
# Etsy Open API v3 (OAuth2).
ETSY_CLIENT_ID=
ETSY_CLIENT_SECRET=
# Faire (wholesale) and Klaviyo (email/SMS) authenticate per-account with an
# API key the customer pastes in the UI — no platform-wide app, nothing here.
# Unified-API aggregator (Merge/Codat/Rutter-style) for the long tail of
# providers. Leave unset until you wire a specific vendor.
UNIFIED_API_PROVIDER=
UNIFIED_API_KEY=
